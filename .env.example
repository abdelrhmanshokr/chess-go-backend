# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/chessgo?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (Phase 2)
JWT_SECRET=your_jwt_secret_change_me
JWT_EXPIRATION=in_minutes
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_me
JWT_REFRESH_EXPIRATION=in_days